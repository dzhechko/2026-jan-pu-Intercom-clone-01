{
  "name": "@ai-consultant/web-widget",
  "version": "1.0.0",
  "private": true,
  "description": "Embeddable chat widget for Cloud.ru AI Consultant",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --minify --outfile=dist/widget.js --format=iife --global-name=CloudRuWidget --target=es2020",
    "dev": "esbuild src/index.ts --bundle --outfile=dist/widget.js --format=iife --global-name=CloudRuWidget --target=es2020 --watch --servedir=.",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
